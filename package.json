{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node tools/update-sitemap.js && vite build",
    "postbuild": "react-snap",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "publicPath": "/portfolio",
    "include": [
      "/",
      "/work",
      "/about",
      "/contact",
      "/work/1",
      "/work/2",
      "/work/3",
      "/work/4",
      "/work/5",
      "/work/6",
      "/work/7",
      "/work/8",
      "/work/9",
      "/work/10",
      "/work/11",
      "/work/12",
      "/work/13",
      "/work/14",
      "/work/15",
      "/work/16",
      "/work/17",
      "/work/18",
      "/work/19",
      "/work/20",
      "/work/21",
      "/work/22",
      "/work/23"
    ],
    "crawl": false,
    "skipThirdPartyRequests": true,
    "headless": true,
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "minifyHtml": {
      "collapseWhitespace": false,
      "removeComments": false
    },
    "saveAs": "html"
  },
  "dependencies": {
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@fontsource/space-mono": "^5.2.9",
    "gsap": "^3.14.2",
    "lenis": "^1.3.17",
    "lucide-react": "^0.562.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "gh-pages": "^6.3.0",
    "globals": "^16.5.0",
    "imagemin": "^9.0.1",
    "imagemin-optipng": "^8.0.0",
    "imagemin-webp": "^8.0.0",
    "postcss": "^8.4.35",
    "react-snap": "^1.23.0",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4"
  }
}
